{
  "uid": "slo-error-budget",
  "title": "SLO / Error Budget",
  "tags": ["sre", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, service)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Availability SLI (5m)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "service:sli_availability:ratio_rate5m{service=\"$service\"}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Error budget remaining (30d)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "1 - ((1 - service:sli_availability:ratio_rate6h{service=\"$service\"}) / (1 - 0.999))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request rate (RED)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "service:http_requests:rate5m{service=\"$service\"}", "legendFormat": "requests/s", "refId": "A" },
        { "expr": "service:http_errors:rate5m{service=\"$service\"}", "legendFormat": "errors/s", "refId": "B" }
      ]
    },
    {
      "id": 4,
      "title": "Error-budget burn rate (1h)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "(1 - service:sli_availability:ratio_rate1h{service=\"$service\"}) / (1 - 0.999)",
          "legendFormat": "burn rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Latency SLI < 300ms (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "service:sli_latency:ratio_rate5m{service=\"$service\"}", "legendFormat": "fast fraction", "refId": "A" }
      ]
    }
  ]
}
